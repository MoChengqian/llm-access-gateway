# Server
APP_SERVER_ADDRESS=:8080
APP_SERVER_READ_HEADER_TIMEOUT_SECONDS=5
APP_SERVER_READ_TIMEOUT_SECONDS=15
APP_SERVER_WRITE_TIMEOUT_SECONDS=60
APP_SERVER_IDLE_TIMEOUT_SECONDS=60
APP_SERVER_MAX_REQUEST_BODY_BYTES=1048576

# Logging
APP_LOG_LEVEL=info

# Observability
APP_OBSERVABILITY_SERVICE_NAME=llm-access-gateway
APP_OBSERVABILITY_OTLP_TRACES_ENDPOINT=
APP_OBSERVABILITY_OTLP_TRACES_INSECURE=false
APP_OBSERVABILITY_OTLP_EXPORT_TIMEOUT_SECONDS=5

# Persistence
APP_MYSQL_DSN=user:pass@tcp(127.0.0.1:3306)/llm_access_gateway?parseTime=true
APP_REDIS_ADDRESS=127.0.0.1:6379
APP_REDIS_PASSWORD=
APP_REDIS_DB=0

# Gateway behavior
APP_GATEWAY_DEFAULT_MODEL=gpt-4o-mini
APP_GATEWAY_PROVIDER_FAILURE_THRESHOLD=1
APP_GATEWAY_PROVIDER_COOLDOWN_SECONDS=30
APP_GATEWAY_PROVIDER_PROBE_INTERVAL_SECONDS=30
APP_GATEWAY_PRIMARY_MOCK_FAIL_CREATE=false
APP_GATEWAY_PRIMARY_MOCK_FAIL_STREAM=false

# Legacy provider env override path. For more than two backends, prefer configs/config.yaml
# provider.backends.
APP_PROVIDER_PRIMARY_TYPE=mock
APP_PROVIDER_PRIMARY_NAME=primary
APP_PROVIDER_PRIMARY_PRIORITY=100
APP_PROVIDER_PRIMARY_BASE_URL=
APP_PROVIDER_PRIMARY_API_KEY=
APP_PROVIDER_PRIMARY_MODEL=
APP_PROVIDER_PRIMARY_MODELS=[]
APP_PROVIDER_PRIMARY_MAX_TOKENS=1024
APP_PROVIDER_PRIMARY_TIMEOUT_SECONDS=15
APP_PROVIDER_PRIMARY_MAX_RETRIES=1
APP_PROVIDER_PRIMARY_RETRY_BACKOFF_MILLISECONDS=200

APP_PROVIDER_SECONDARY_TYPE=mock
APP_PROVIDER_SECONDARY_NAME=secondary
APP_PROVIDER_SECONDARY_PRIORITY=200
APP_PROVIDER_SECONDARY_BASE_URL=
APP_PROVIDER_SECONDARY_API_KEY=
APP_PROVIDER_SECONDARY_MODEL=
APP_PROVIDER_SECONDARY_MODELS=[]
APP_PROVIDER_SECONDARY_MAX_TOKENS=1024
APP_PROVIDER_SECONDARY_TIMEOUT_SECONDS=15
APP_PROVIDER_SECONDARY_MAX_RETRIES=1
APP_PROVIDER_SECONDARY_RETRY_BACKOFF_MILLISECONDS=200
